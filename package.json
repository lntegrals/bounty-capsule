{
  "name": "bounty-capsule",
  "version": "1.0.0",
  "description": "On-chain bounty market using XRPL Escrow and Pinata IPFS",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node src/server/index.js",
    "client": "cd src/client && npm run dev",
    "build": "cd src/client && npm run build",
    "seed": "node src/scripts/seed.js"
  },
  "dependencies": {
    "@pinata/sdk": "^2.1.0",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "xrpl": "^3.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
