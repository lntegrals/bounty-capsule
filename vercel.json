{
  "version": 2,
  "installCommand": "npm install && cd src/client && npm install",
  "buildCommand": "cd src/client && node node_modules/.bin/vite build",
  "outputDirectory": "src/client/dist",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
